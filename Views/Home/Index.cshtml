@{
    ViewData["Title"] = "Home";
}

<div class="text-center py-5">
    <h1 class="display-4 fw-bold" style="color:#1a1a2e;">Stay Organized.<br/>Get Things Done.</h1>
    <p class="lead text-muted mt-3">Manage your daily tasks in one place. Simple, fast, and effective.</p>
    <div class="mt-4">
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <a href="/Tasks" class="btn btn-lg px-5 text-white" style="background-color:#e94560;">Go to My Tasks →</a>
        }
        else
        {
            <a href="/Account/Register" class="btn btn-lg px-5 text-white me-3" style="background-color:#e94560;">Get Started Free</a>
            <a href="/Account/Login" class="btn btn-lg btn-outline-secondary px-5">Login</a>
        }
    </div>
</div>

<div class="row mt-5 g-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 text-center p-4">
            <div style="font-size:2.5rem;">📝</div>
            <h5 class="mt-3 fw-bold">Create Tasks</h5>
            <p class="text-muted">Add tasks with titles and descriptions instantly.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 text-center p-4">
            <div style="font-size:2.5rem;">✏️</div>
            <h5 class="mt-3 fw-bold">Track Progress</h5>
            <p class="text-muted">Mark tasks as done and keep track of what's pending.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 text-center p-4">
            <div style="font-size:2.5rem;">🔒</div>
            <h5 class="mt-3 fw-bold">Secure Access</h5>
            <p class="text-muted">Your tasks are private. Login required to access them.</p>
        </div>
    </div>
</div>