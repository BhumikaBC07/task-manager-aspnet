@model IEnumerable<TaskManagerApp.Models.TaskItem>

@{
    ViewData["Title"] = "My Tasks";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold" style="color:#1a1a2e;">📋 My Tasks</h2>
    <a href="/Tasks/Create" class="btn text-white px-4" style="background-color:#e94560;">+ Add New Task</a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <p style="font-size:3rem;">📭</p>
        <p class="text-muted">No tasks yet. Create your first one!</p>
        <a href="/Tasks/Create" class="btn text-white px-4" style="background-color:#e94560;">+ Add Task</a>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var task in Model)
        {
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <h5 class="card-title fw-bold">@task.Title</h5>
                            @if (task.IsCompleted)
                            {
                                <span class="badge bg-success">Done</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Pending</span>
                            }
                        </div>
                        <p class="card-text text-muted">
                            @(task.Description != null && task.Description.Length > 100
                                ? task.Description.Substring(0, 100) + "..."
                                : task.Description)
                        </p>
                        <small class="text-muted">Created: @task.CreatedAt.ToString("dd MMM yyyy")</small>
                    </div>
                    <div class="card-footer bg-white border-0 d-flex gap-2">
                        <a href="/Tasks/Edit/@task.Id" class="btn btn-sm btn-outline-primary">✏️ Edit</a>
                        <a href="/Tasks/Delete/@task.Id" class="btn btn-sm btn-outline-danger">🗑️ Delete</a>
                    </div>
                </div>
            </div>
        }
    </div>
}