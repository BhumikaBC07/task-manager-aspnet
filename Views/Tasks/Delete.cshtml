@model TaskManagerApp.Models.TaskItem

@{
    ViewData["Title"] = "Delete Task";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4 text-center">
                <div style="font-size:3rem;">⚠️</div>
                <h4 class="fw-bold mt-2">Delete Task?</h4>
                <p class="text-muted">You are about to delete:</p>
                <p class="fw-bold fs-5">@Model.Title</p>
                <p class="text-muted small">@Model.Description</p>
                <form method="post" class="d-flex justify-content-center gap-3 mt-4">
                    <button type="submit" class="btn btn-danger px-4">Yes, Delete</button>
                    <a href="/Tasks" class="btn btn-outline-secondary px-4">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>